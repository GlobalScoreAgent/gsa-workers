# Copy to .env for local runs (never commit .env)
SUPABASE_DB_URL=postgresql://...
CHAIN=ethereum
SHARD=0
SHARDS=1
WALLET_BATCH_SIZE=50
CLAIM_STALE_SECONDS=7200
MAX_RUNTIME_SECONDS=19800
ACTIVITY_CATCHUP_MAX_DAYS=3
LOG_CHUNK_BLOCKS=2000
LOG_CHUNK_MIN=50
LOG_CHUNK_MAX=10000
RPC_MIN_INTERVAL_MS=150
RPC_RETRY_BASE_SECONDS=1
WORKER_ID=activity-local
