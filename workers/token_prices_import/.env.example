# Copy to .env for local runs (never commit .env)
SUPABASE_DB_URL=postgresql://...
COINGECKO_KEY=your_coingecko_demo_or_pro_key
# demo → api.coingecko.com + x-cg-demo-api-key
# pro  → pro-api.coingecko.com + x-cg-pro-api-key
COINGECKO_API_PLAN=demo
PRICE_CACHE_TTL_HOURS=24
MIN_LIQUIDITY_USD=1000
MAX_RUNTIME_SECONDS=19800
